# ── CDP SDK ─────────────────────────────────────────────────────────────────────
# Coinbase Developer Platform credentials (get from https://portal.cdp.coinbase.com/)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Optional: known wallet address to restore on boot.
# Set this if your wallet was originally created by AgentKit/MCP server (which uses
# cdp.evm.createAccount() rather than a named account). If unset, the bot creates/
# restores an account named 'coinbase-trade-bot' using getOrCreateAccount().
WALLET_ADDRESS=

# ── 0x API (swap quotes fallback) ───────────────────────────────────────────────
# Optional: enables 0x API fallback for swap quotes (https://dashboard.0x.org/)
ZEROX_API_KEY=

# Network(s) to make available. Comma-separated; first entry is the default active network.
# Single network:  NETWORK_ID=base-sepolia
# Multi-network:   NETWORK_ID=base-sepolia,base-mainnet  (switch at runtime via UI or Telegram)
NETWORK_ID=base-sepolia,base-mainnet

# ── Telegram ────────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Comma-separated list of chat IDs allowed to control the bot
TELEGRAM_ALLOWED_CHAT_IDS=YOUR_CHAT_ID

# ── Strategy ───────────────────────────────────────────────────────────────────
# threshold — buy on price drop %, sell on price rise % from entry
# sma       — SMA crossover (short window crosses above/below long window)
STRATEGY=threshold

# Threshold strategy: trigger thresholds (percentages)
PRICE_DROP_THRESHOLD_PCT=2.0
PRICE_RISE_TARGET_PCT=3.0

# SMA strategy: window sizes (number of price snapshots)
SMA_SHORT_WINDOW=5
SMA_LONG_WINDOW=20

# ── Polling & trading intervals ────────────────────────────────────────────────
# How often to poll price and wallet balance (seconds)
POLL_INTERVAL_SECONDS=120

# How often to evaluate the strategy and potentially trade (seconds)
TRADE_INTERVAL_SECONDS=60

# ── Risk limits ────────────────────────────────────────────────────────────────
# Maximum ETH to sell per trade
MAX_TRADE_SIZE_ETH=0.01

# Maximum USDC to spend per buy trade
MAX_TRADE_SIZE_USDC=10

# Minimum time between trades (seconds) — prevents rapid repeated execution
TRADE_COOLDOWN_SECONDS=600

# ── Web dashboard ──────────────────────────────────────────────────────────────
WEB_PORT=3003

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Dry run ────────────────────────────────────────────────────────────────────
# true  — log trades without executing them (safe for testing)
# false — execute real swaps on-chain
# Start with true until you have confirmed the bot is behaving as expected.
DRY_RUN=true

# ── Data storage ───────────────────────────────────────────────────────────────
# Leave unset to use a Docker-managed named volume (default, recommended).
# Set to an absolute host path to use a bind mount instead.
#   IMPORTANT: must be on a POSIX filesystem (not SMB/CIFS) — SQLite requires
#   proper file locking. The directory must exist and be owned by UID 1000:
#   mkdir -p /home/pi/.coinbase-trade && chown 1000:1000 /home/pi/.coinbase-trade
TRADE_DATA_PATH=

# ── Alchemy ─────────────────────────────────────────────────────────────────────
# Optional: Alchemy API key for ERC20 token auto-discovery
ALCHEMY_API_KEY=
