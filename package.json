{
  "name": "coinbase-trade-base-sepolia",
  "version": "0.1.0",
  "description": "Autonomous trading bot for base-sepolia testnet via Coinbase AgentKit MCP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && npm run build:frontend && cp src/web/public/login.html src/web/public/setup.html dist/web/public/",
    "build:frontend": "cd src/frontend && npm run build",
    "dev:frontend": "cd src/frontend && npm run dev",
    "cli": "tsx cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.48.0",
    "@simplewebauthn/server": "^13.3.0",
    "better-sqlite3": "^9.6.0",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "telegraf": "^4.16.3",
    "viem": "^2.48.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.0"
  }
}
