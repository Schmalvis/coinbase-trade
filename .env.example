MCP_SERVER_URL=http://YOUR_MCP_SERVER_IP:3002/mcp

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=123456789

POLL_INTERVAL_SECONDS=30
TRADE_INTERVAL_SECONDS=60

# Strategy: 'threshold' or 'sma'
STRATEGY=threshold
# Threshold strategy: buy if price drops X%, sell if up Y% from entry
PRICE_DROP_THRESHOLD_PCT=2.0
PRICE_RISE_TARGET_PCT=3.0
# SMA strategy: short/long window (in number of snapshots)
SMA_SHORT_WINDOW=5
SMA_LONG_WINDOW=20

MAX_TRADE_SIZE_ETH=0.01
TRADE_COOLDOWN_SECONDS=300

WEB_PORT=8080
LOG_LEVEL=info

# NOTE: tsx/esm cold-start takes ~15s on Pi — this is normal, not a hang

# Data directory — must be on local storage, NOT the SMB share (SQLite locking)
DATA_DIR=/home/pi/.local/share/coinbase-trade/base-sepolia

# Set to true to log trades without executing them
DRY_RUN=true
